# =============================================================================
# Sovereign Dialect-Bridge — Backend Environment Variables
# Copy file ini ke `.env` dan isi nilai yang sesuai. JANGAN commit `.env`.
# =============================================================================

# Django secret key — generate via:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=ganti-dengan-string-acak-minimal-50-karakter

# Set False di production. True hanya untuk development lokal.
DEBUG=True

# Comma-separated. Production: tambah domain HF Space.
#   ALLOWED_HOSTS=localhost,127.0.0.1,oinovenv-sovereign-dialect-bridge-api.hf.space
ALLOWED_HOSTS=localhost,127.0.0.1

# Database URL — Supabase Postgres (Session Pooler), dipakai dev maupun production.
# Supabase: Project Settings → Database → Connection String → Session Pooler URI
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres

# Persistent DB connection per worker (detik). 0 = re-open setiap request.
# 60 default — kurangi handshake overhead tanpa hold koneksi terlalu lama di pooler.
DB_CONN_MAX_AGE=60

# Cloudinary — OPSIONAL. Kosongkan ketiganya untuk skip image storage.
# Dapatkan dari https://cloudinary.com/ Dashboard.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CORS — daftar origin frontend, comma-separated.
# Production: tambahkan URL Vercel (tanpa trailing slash).
#   CORS_ALLOWED_ORIGINS=http://localhost:3000,https://sovereign-dialect-bridge.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Hugging Face token — opsional untuk download model dan wajib jika dashboard
# backend ingin proxy runtime/build logs HF Space via /dashboard/api/logs/.
# Buat token di https://huggingface.co/settings/tokens dengan permission Read.
HF_TOKEN=

# Pre-load model NLP berat (mT5 2.2 GB + IndoBERT NER) saat startup.
# DEFAULT false → `runserver` lokal cepat. Set true hanya jika packages NLP
# (torch, transformers, joblib, sumy, langdetect) terinstal dan model tersedia.
NLP_ENABLED=false

# Summarizer utama untuk hasil aduan production.
# Pilihan: mt5, indot5, textrank, ner, first_sentences.
SUMMARIZER_MODEL=mt5

# Urutan fallback kalau summarizer utama belum loaded/gagal.
SUMMARIZER_FALLBACKS=ner,textrank,first_sentences

# Model abstractive yang di-warmup untuk dashboard comparison.
# Untuk hemat RAM production, bisa set hanya: mt5 atau indot5.
WARMUP_SUMMARIZERS=mt5,indot5

# Checkpoint summarizer abstractive.
MT5_MODEL_PATH=OinoVenv/sovereign-mt5-nusasum
INDOT5_MODEL_PATH=OinoVenv/sovereign-indot5-nusasum

# Default true supaya bahasa unsupported NLLB (mis. Madura/Batak Toba) tetap
# punya jalur translasi fallback saat deploy.
ALLOW_EXTERNAL_TRANSLATION=true

# Google Sign-In — isi dengan OAuth Client ID dari Google Cloud Console.
# Nilai ini harus sama dengan NEXT_PUBLIC_GOOGLE_CLIENT_ID di frontend.
GOOGLE_CLIENT_ID=

# Reset password email-only.
# WAJIB False di production. True hanya untuk dev lokal — kode 6-digit
# ikut di-return di body response API supaya bisa di-copy tanpa email.
PASSWORD_RESET_CODE_TTL_MINUTES=10
PASSWORD_RESET_MAX_ATTEMPTS=5
PASSWORD_RESET_DEBUG_CODE=False

# Email backend:
# - Lokal dev tanpa SMTP setup: pakai `console.EmailBackend` → kode reset
#   tampil di terminal Django, tidak benar-benar terkirim.
# - Production: WAJIB `smtp.EmailBackend` + isi EMAIL_HOST/USER/PASSWORD di bawah.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=Sovereign Dialect-Bridge <no-reply@localhost>

# Production SMTP — pilih salah satu provider.
# Setup guide lengkap (Gmail App Password / Resend / Brevo): docs/DEPLOYMENT.md §3.1
#
# Gmail (5 menit setup, ~500/hari, gratis):
#   1. Aktifkan 2FA di https://myaccount.google.com/security
#   2. Buat App Password di https://myaccount.google.com/apppasswords
#   3. Paste 16-char password ke EMAIL_HOST_PASSWORD (hapus spasi)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=bot.dialectbridge@gmail.com
# EMAIL_HOST_PASSWORD=abcdefghijklmnop
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=Sovereign Dialect-Bridge <bot.dialectbridge@gmail.com>
#
# Resend (deliverability lebih baik, 3000/bulan free, butuh domain untuk From custom):
# EMAIL_HOST=smtp.resend.com
# EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD=re_xxxxxxxxxxxxxxxxxxxx
#
# Brevo (300/hari unlimited bulanan):
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_HOST_USER=<login_smtp_brevo>
# EMAIL_HOST_PASSWORD=<smtp_key_brevo>
