# =============================================================================
# Sovereign Dialect-Bridge — Backend Environment Variables
# Copy file ini ke `.env` dan isi nilai yang sesuai. JANGAN commit `.env`.
# =============================================================================

# Django secret key — generate via:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=ganti-dengan-string-acak-minimal-50-karakter

# Set False di production. True hanya untuk development lokal.
DEBUG=True

# Comma-separated. Tambahkan domain Railway saat deploy, misal:
#   ALLOWED_HOSTS=localhost,127.0.0.1,sovereign-bridge.up.railway.app
ALLOWED_HOSTS=localhost,127.0.0.1

# Database URL — Supabase Postgres, dipakai untuk dev maupun production.
# Supabase: Project Settings → Database → Connection String → Session Pooler URI
DATABASE_URL=postgresql://postgres:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Cloudinary — OPSIONAL. Kosongkan ketiganya untuk skip image storage.
# Dapatkan dari https://cloudinary.com/ Dashboard.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CORS — daftar origin frontend, comma-separated.
# Production: tambahkan URL Vercel.
#   CORS_ALLOWED_ORIGINS=http://localhost:3000,https://sovereign-bridge.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000
